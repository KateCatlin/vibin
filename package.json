{
  "name": "@vibin-cli/vibin",
  "version": "0.2.0",
  "description": "A pre-launch sanity checker for vibe coders.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "vibin": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "prepack": "npm run build",
    "smoke": "npm run build && node dist/cli.js --help"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "playwright": "^1.52.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
